{
  "hooks": {
    "SessionStart": {
      "matcher": "startup|resume",
      "type": "command",
      "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/start.sh",
      "timeout": 5
    },
    "SessionEnd": {
      "matcher": "*",
      "type": "command",
      "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/stop.sh",
      "timeout": 5
    }
  }
}
