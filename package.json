{
  "name": "agent-mode-discord",
  "displayName": "Agent Mode",
  "description": "Discord Rich Presence for Claude Code and AI coding agents.",
  "version": "0.0.1",
  "publisher": "agent-mode-dev",
  "engines": { "vscode": "^1.93.0" },
  "main": "./dist/extension.cjs",
  "activationEvents": ["onStartupFinished"],
  "categories": ["Other"],
  "capabilities": {
    "untrustedWorkspaces": { "supported": true },
    "virtualWorkspaces": false
  },
  "repository": { "type": "git", "url": "https://github.com/TODO/agent-mode-discord.git" },
  "license": "MIT",
  "contributes": {},
  "scripts": {
    "build": "node esbuild.mjs --production",
    "build:dev": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "check:api-surface": "node scripts/check-api-surface.mjs",
    "check:no-network": "node scripts/check-no-network.mjs",
    "check:config-keys": "node scripts/check-config-keys.mjs",
    "check:pack-inlined": "node scripts/check-pack-inlined.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.93.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
